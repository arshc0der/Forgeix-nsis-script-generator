  <property name="styleSheet">
   <string notr="true">#centralwidget {
    background-color: rgba(20, 35, 60, 120);  /* soft blue glass */
    border: 1px solid rgba(255, 255, 255, 25);
    border-radius: 18px;
}

QMainWindow {
    background: transparent;
}

/* LEFT + RIGHT PANELS */
#leftPanel, #rightPanel {
    background-color: rgba(25, 25, 35, 160);
    border: 1px solid rgba(255,255,255,15);
    border-radius: 16px;
}

/* TITLE BAR */
#titleBar {
    background-color: rgba(10, 10, 15, 180);
    border-top-left-radius: 16px;
    border-top-right-radius: 16px;
}

/* LABELS */
QLabel {
    color: rgba(255,255,255,200);
    font-size: 12px;
}

/* INPUT FIELDS */
QLineEdit {
    background-color: rgba(255,255,255,18);
    border: 1px solid rgba(255,255,255,25);
    border-radius: 8px;
    color: white;
    padding: 6px;
}

QLineEdit:hover {
    border: 1px solid rgba(10,132,255,60);
}

QLineEdit:focus {
    border: 1px solid #0A84FF;
    background-color: rgba(255,255,255,22);
}

/* BUTTONS */
QPushButton {
    background-color: rgba(255,255,255,20);
    border: 1px solid rgba(255,255,255,20);
    border-radius: 10px;
    color: white;
    padding: 7px 12px;
}

QPushButton:hover {
    background-color: rgba(255,255,255,30);
    border: 1px solid rgba(10,132,255,60);
}

QPushButton:pressed {
    background-color: rgba(10,132,255,25);
}

QPushButton:focus {
    border: 1px solid #0A84FF;
}

/* LOG CONSOLE */
QTextEdit {
    background-color: rgba(0,0,0,80);
    border-radius: 8px;
    color: #00ff99;
    font-family: Consolas;
}

/*Check Box*/

QCheckBox {
    color: white;
    font-size: 13px;
    spacing: 8px;
}

/* box */
QCheckBox::indicator {
    width: 16px;
    height: 16px;

    border-radius: 4px;

    background-color: rgba(255, 255, 255, 18);
    border: 1px solid rgba(255, 255, 255, 28);
}

/* hover */
QCheckBox::indicator:hover {
    border: 1px solid rgba(10, 132, 255, 120);
}

/* checked state (IMPORTANT FIX HERE) */
QCheckBox::indicator:checked {
    background-color: #0A84FF;
    border: 1px solid #0A84FF;
    image: url(:/res/RES/icons/check.svg);
}


/* ===========================
   QScrollArea
   =========================== */

QScrollArea {
    background: transparent;
    border: none;
}

QScrollArea &gt; QWidget &gt; QWidget {
    background: transparent;
}

/* ===========================
   Vertical ScrollBar
   =========================== */

QScrollBar:vertical {
    background: transparent;
    width: 10px;
    margin: 4px 0px 4px 0px;
    border: none;
}

QScrollBar::handle:vertical {
    background: rgba(255,255,255,50);
    min-height: 40px;
    border-radius: 5px;
}

QScrollBar::handle:vertical:hover {
    background: rgba(10,132,255,180);
}

QScrollBar::handle:vertical:pressed {
    background: #0A84FF;
}

QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical {
    height: 0px;
    border: none;
    background: none;
}

QScrollBar::add-page:vertical,
QScrollBar::sub-page:vertical {
    background: transparent;
}

/* ===========================
   Horizontal ScrollBar
   =========================== */

QScrollBar:horizontal {
    background: transparent;
    height: 10px;
    margin: 0px 4px 0px 4px;
    border: none;
}

QScrollBar::handle:horizontal {
    background: rgba(255,255,255,50);
    min-width: 40px;
    border-radius: 5px;
}

QScrollBar::handle:horizontal:hover {
    background: rgba(10,132,255,180);
}

QScrollBar::handle:horizontal:pressed {
    background: #0A84FF;
}

QScrollBar::add-line:horizontal,
QScrollBar::sub-line:horizontal {
    width: 0px;
    border: none;
    background: none;
}

QScrollBar::add-page:horizontal,
QScrollBar::sub-page:horizontal {
    background: transparent;
}

/* Remove arrow buttons */
QScrollBar::up-arrow,
QScrollBar::down-arrow,
QScrollBar::left-arrow,
QScrollBar::right-arrow {
    background: none;
    width: 0px;
    height: 0px;
}</string>
