                   <string notr="true">QTreeWidget {
    background-color: rgba(25, 25, 30, 160);
    border: 1px solid rgba(255, 255, 255, 15);
    border-radius: 10px;

    color: white;

    padding: 6px;
    outline: none;
}

/* Header */
QHeaderView::section {
    background-color: rgba(255, 255, 255, 10);
    color: rgba(255,255,255,200);

    padding: 6px;

    border: none;
    border-bottom: 1px solid rgba(255,255,255,15);
}

/* Items */
QTreeWidget::item {
    padding: 6px;
    border-radius: 6px;
}

/* Hover */
QTreeWidget::item:hover {
    background-color: rgba(255, 255, 255, 12);
}

/* Selected item (Apple blue) */
QTreeWidget::item:selected {
    background-color: rgba(10, 132, 255, 35);
    color: white;
}

/* Focus outline */
QTreeWidget:focus {
    border: 1px solid #0A84FF;
}</string>
