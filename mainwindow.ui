                   </item>
                   <item>
                    <widget class="QComboBox" name="guiStyleComboBox">
                     <property name="styleSheet">
                      <string notr="true">QComboBox {
    background-color: rgba(255, 255, 255, 20);
    color: white;

    border: 1px solid rgba(255, 255, 255, 25);
    border-radius: 8px;

    padding: 6px 12px;

    min-height: 28px;
}

QComboBox:hover {
    background-color: rgba(255,255,255,30);
    border: 1px solid rgba(90,140,255,120);
}

QComboBox:focus {
    border: 1px solid rgb(0,122,255);
}

QComboBox:disabled {
    background-color: rgba(255,255,255,10);
    color: rgba(255,255,255,80);
}

/* Arrow area */
QComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: top right;

    width: 30px;

    border: none;
    background: transparent;
}

/* Arrow */
QComboBox::down-arrow {
    image: url(:/res/RES/icons/chevron-down.svg);
    width: 12px;
    height: 12px;
}

/* Popup list */
QComboBox QAbstractItemView {

    background-color: rgba(35,35,40,240);

    color: white;

    border: 1px solid rgba(255,255,255,20);

    border-radius: 8px;

    outline: none;

    selection-background-color: rgba(0,122,255,180);

    selection-color: white;

    padding: 4px;
}

/* Items */
QComboBox QAbstractItemView::item {
    height: 28px;
    padding-left: 10px;
    border-radius: 6px;
}

/* Hover item */
QComboBox QAbstractItemView::item:hover {
    background-color: rgba(255,255,255,18);
}

/* Selected item */
QComboBox QAbstractItemView::item:selected {
    background-color: rgba(0,122,255,180);
    color: white;
}</string>
